# ─────────────────────────────────────────────────────────────────────────────
# MerchantHub environment configuration
# Copy to `.env` and adjust. The defaults below run the full stack locally
# against a Dockerized Postgres with no external Supabase account required.
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres (admin / Flyway) ────────────────────────────────────────────────
POSTGRES_DB=merchanthub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Restricted application DB role (RLS is enforced against this role) ────────
APP_DB_USER=merchanthub_app
APP_DB_PASSWORD=merchanthub_app_pw

# ── Backend (Spring Boot) ────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
BACKEND_PORT=8080

# Supabase JWT secret. For local dev this is a shared HS256 secret used both to
# validate tokens and (in dev) to mint dev tokens. In production, set this to
# your Supabase project's JWT secret (Project Settings → API → JWT Secret).
SUPABASE_JWT_SECRET=super-secret-dev-jwt-signing-key-change-me-please-32b

# Enables POST /api/auth/dev-token (NEVER enable in production).
DEV_AUTH_ENABLED=true

# HMAC secret used to verify inbound shop webhooks (X-Shop-Signature header).
WEBHOOK_SECRET=dev-webhook-hmac-secret-change-me

# Scheduled pull-sync interval (ms). 0 disables the scheduler.
SYNC_INTERVAL_MS=300000

# ── Mock shop API ────────────────────────────────────────────────────────────
MOCK_SHOP_PORT=4000
# URL the backend uses to reach the mock shop API.
SHOP_API_BASE_URL=http://mock-shop-api:4000
# URL the mock shop API uses to deliver webhooks back to the backend.
BACKEND_WEBHOOK_URL=http://backend:8080/api/webhooks/orders

# ── Kafka + notification-service (event-driven microservice) ─────────────────
KAFKA_PORT=9092
# Broker address the backend + notification-service connect to (inside the network).
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# How often the backend's outbox publisher relays pending events to Kafka (ms).
OUTBOX_POLL_MS=2000
# Notification microservice HTTP port.
NOTIFICATION_PORT=8081

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
FRONTEND_PORT=3000
# Browser-visible URL of the backend API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Supabase project (optional for local dev — leave blank to use dev-token auth
# and polling instead of Supabase Auth + Realtime).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
