# Copy to `.env.local` for local development.
# All vars are NEXT_PUBLIC_ and therefore inlined into the client bundle.

# Browser-visible URL of the Spring Boot backend API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Supabase project (OPTIONAL). Leave BOTH blank to use dev-token auth and
# 10-second alert polling. Set both to enable Supabase Auth + Realtime.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
